{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "esnext",
    "strict": true,
    "moduleResolution": "node",
    "downlevelIteration": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "types": ["bun-types"]
  }
}
